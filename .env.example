# Provider selection. Defaults are fully local when these values are omitted.
LLM_PROVIDER=ollama
EMBEDDING_PROVIDER=ollama

# Ollama local mode
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TEXT_MODEL=llama3.1
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT_SECONDS=20
OLLAMA_RETRY_ATTEMPTS=2
OLLAMA_RETRY_DELAY_SECONDS=0.5

# Optional hosted mode (set both providers to `openai` on Railway).
# Keep OPENAI_API_KEY empty here; configure it as a Railway secret.
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_OUTPUT_TOKENS=240
OPENAI_RETRY_ATTEMPTS=2
OPENAI_RETRY_DELAY_SECONDS=0.5

# Chroma persistence. On Railway override this with /data/chroma_db and mount that path.
CHROMA_PERSIST_DIR=./chroma_db
RAG_COLLECTION_NAME=insightflow_context
