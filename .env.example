# Local development defaults use http://localhost:11434.
# On Railway, set this to the private URL of the Ollama service.
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_TEXT_MODEL=llama3.1
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT_SECONDS=20
OLLAMA_RETRY_ATTEMPTS=2
OLLAMA_RETRY_DELAY_SECONDS=0.5

# Mount a persistent Railway volume at this location for the app service.
CHROMA_PERSIST_DIR=/data/chroma_db
RAG_COLLECTION_NAME=insightflow_context
